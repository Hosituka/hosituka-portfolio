---
//このファイルはトップページに当たります。
import Layout from '../layouts/Layout.astro';

import GrobalNav from '../components/GlobalNav.astro';
import AboutMeCard from '../components/AboutMeCard.astro';
import Footer from '../components/Footer.astro';

import Carousel1 from '../components/MyCarousel.astro';
import GameCardOfCarousel1 from '../components/GameCardOfCarousel.astro';
import CardOfCarousel2 from '../components/CardOfCarousel.astro';
import GameCardOfCarousel3 from '../components/GameCardOfCarousel.astro';
import GameCardOfCarousel4 from '../components/GameCardOfCarousel.astro';
import GameCardOfCarousel5 from '../components/GameCardOfCarousel.astro';
import GameCardOfCarousel6 from '../components/GameCardOfCarousel.astro';

import './index.scss';

---
<Layout title='ホーム'>
	<GrobalNav topURL ="/" worksURL="/works.astro"devLogURL="/devLog.astro"  sNS_URL="/sns.astro" />
	<header>
		<div class="page-title-container">
			<h1>Hositukaの</h1><h1>ホームページ</h1>
		</div>
	</header>
	<main>
		<section class="about-me-section">
			<h2>私について</h2>
			<div class="about-me-main">
				<AboutMeCard/>
				<p class="about-me-text">
					主にブラウザ上で遊ぶゲームをunityで作っています。最近はweb(フロントエンド)の勉強も始めました。拙い部分が目立つと思いますが、温かい目で見守ってください。
				</p>
				<div class="sns-container">
					<a href="https://unityroom.com/users/hosi">
						<img src="/icon/UnityRoomLogo.webp" alt="UnityRoomLogo">
					</a>
					<a href="https://x.com/hosituka">
						<img src="/icon/X_Logo.svg" alt="X_Logo">
					</a>
					<a href="https://github.com/Hosituka">
						<img src="/icon/GitHubLogo.svg" alt="GitHubLogo">
					</a>
					<a href="https://connpass.com/user/hosituka/">
						<img class="is-small" src="/icon/ConnpassLogo.webp" alt="ConnpassLogo">
					</a>
				</div>
			</div>
		</section>
		<section class="main-works">
			<h2>主要な作品</h2>
			<div class="carousel-container" >
				<Carousel1 speed={-1}>
					<GameCardOfCarousel1 gameTitle='GunSwapShooter' gameImageURL='/icon/MyIcon.webp'>
						<strong>・使用技術</strong>
						：unity,c#,blender,<br>
						shadergraph,git/github<br>
						<strong>・制作期間</strong>
						：2025/11月～2026/3月。<br>
						<strong>・概要</strong>
						：webARシューティングゲーム<br>
						7作目です。現状コーディングの成長的にも、ゲームの楽しさ的にも一番なゲームです。ぜひ遊んでね

					</GameCardOfCarousel1>
					<CardOfCarousel2 workTitle='ポートフォリオサイト' workImageURL='/icon/MyIcon.webp'>
						<strong>・使用技術</strong>
						：Astro,scss,typescript,<br>
						git/github<br>
						<strong>・制作期間</strong>
					    ：2026/3月～現在まで。<br>
						<strong>・概要</strong>
						：８作目、このサイトの事<br>
						自己分析の一環として自分について、まとめるサイトが欲しくなって作りました。苦戦はしましたが、楽しかったです。
					</CardOfCarousel2>
					<GameCardOfCarousel3 gameTitle='test3' gameImageURL='/icon/MyIcon.webp'>
						<ul slot="teck-list">
							<li>hoge1</li>
							<li>hoge2</li>
							<li>hoge3</li>
							<li>hoge4</li>
							<li>hoge5</li>
						</ul>
					</GameCardOfCarousel3>
					<GameCardOfCarousel4 gameTitle='test4' gameImageURL='/icon/MyIcon.webp'>
						<ul slot="teck-list">
							<li>hoge1</li>
							<li>hoge2</li>
							<li>hoge3</li>
							<li>hoge4</li>
							<li>hoge5</li>
						</ul>
					</GameCardOfCarousel4>
					<GameCardOfCarousel5 gameTitle='test5' gameImageURL='/icon/MyIcon.webp'>
						<ul slot="teck-list">
							<li>hoge1</li>
							<li>hoge2</li>
							<li>hoge3</li>
							<li>hoge4</li>
							<li>hoge5</li>
						</ul>
					</GameCardOfCarousel5>
					<GameCardOfCarousel6 gameTitle='test6' gameImageURL='/icon/MyIcon.webp'>
						<ul slot="teck-list">
							<li>hoge1</li>
							<li>hoge2</li>
							<li>hoge3</li>
							<li>hoge4</li>
							<li>hoge5</li>
						</ul>
					</GameCardOfCarousel6>

				</Carousel1>
			</div>
			<div class="main-works-footer">

			</div>

		</section>
	</main>
	<Footer/>
</Layout>
