---
//このファイルはトップページに当たります。
import Layout from '../layouts/Layout.astro';

import AboutMeCard from '../components/index/AboutMeCard.astro';
import ParticleBackGround from '../components/ParticleBackGround.astro'

import Carousel from '../components/MyCarousel.astro';
import CardOfCarousel from '../components/index/WorkCardOfCarousel.astro';

---
<Layout title='ホーム'>
	<ParticleBackGround zIndex={1} particleDensity={0.5}/>
	<header>
		<div class="page-title-container">
			<h1>Hositukaの</h1><h1>ホームページ</h1>
		</div>
	</header>
	<main>
		<section class="about-me-section">
			<h2>私について</h2>
			<div class="about-me-main">
				<AboutMeCard/>
				<p class="about-me-text">
					主にブラウザ上で遊べる3DゲームをUnityで制作しています。最近はWebフロントエンドの学習にも取り組んでおり、このサイトではこれまでの制作物や学んだことを整理して発信しています。
				</p>
				<div class="sns-wrapper">
					<a href="https://unityroom.com/users/hosi" target="_blank" rel="noopener noreferrer">
						<img src="/icon/unityRoomLogo.webp" alt="UnityRoomLogo">
					</a>
					<a href="https://x.com/hosituka" target="_blank" rel="noopener noreferrer">
						<img src="/icon/xLogo.svg" alt="X_Logo">
					</a>
					<a href="https://github.com/Hosituka" target="_blank" rel="noopener noreferrer">
						<img src="/icon/teckTools/gitHubLogo.svg" alt="GitHubLogo">
					</a>
					<a href="https://connpass.com/user/hosituka/" target="_blank" rel="noopener noreferrer">
						<img class="is-small" src="/icon/connpassLogo.webp" alt="ConnpassLogo">
					</a>
				</div>
				<a class="link-about-me" href="/aboutMe">自己紹介のページへ</a>
			</div>
		</section>
		<section class="main-works-section">
			<h2>主要な作品</h2>
			<div class="carousel-container" >
				<Carousel speed={-80}>
					<CardOfCarousel workTitle='ポートフォリオサイト' workMediaURL='/video/portfolioSite.mp4' detailLink='https://github.com/Hosituka/hosituka-portfolio'>
						<strong>・制作期間</strong>
					    ：2026/3月～現在まで。<br>
						<strong>・概要</strong>
						：8作目、このサイトの事<br>
						自己分析と作品整理を目的に制作したポートフォリオサイトです。ゲーム制作で培った表現への関心を活かしつつ、AstroやTypeScript、SCSSを学ぶきっかけになりました。
					</CardOfCarousel>
					<CardOfCarousel workTitle='GunSwapShooter※スマホのみ' workMediaURL='/video/gunSwapShooter.mp4' playLink='https://unityroom.com/games/gun_swap_shooter' detailLink='https://github.com/Hosituka/GunSwapShooter'>
						<strong>・制作期間</strong>
						：2025/11月～2026/3月。<br>
						<strong>・概要</strong>
						：webARシューティングゲーム<br>
						1年半ぶりに制作した、スマートフォン向けのWebARシューティングゲームです。ゲーム性と実装の両面で特に成長を感じた作品で、Git/GitHubを本格的に活用するきっかけにもなりました。

					</CardOfCarousel>
					<CardOfCarousel workTitle='音ゲー※中止' workMediaURL='/video/musicGame.mp4'>
						<strong>・制作期間</strong>
						：2023/7月～2024/5月中止<br>
						<strong>・概要</strong>
						：音楽ゲームの操作感をテーマに制作した試作作品です。完成には至りませんでしたが、GIMPとShaderGraphを組み合わせたビジュアル制作や、操作性設計の難しさを学ぶきっかけになりました。
					</CardOfCarousel>

					<CardOfCarousel workTitle='PIRATE SHIP' workMediaURL='/video/pirateShip.mp4' playLink='https://unityroom.com/games/hositukage-mu6'>
						<strong>・制作期間</strong>
						：2021/4月～2023/7月。<br>
						<strong>・概要</strong>
						：6作目として制作した、船を題材にしたオープンワールド風ゲームです。規模の見積もりや操作性には課題が残りましたが、ShaderGraphを学び、海やスカイボックスなどのビジュアル表現を自作する経験につながりました。
					</CardOfCarousel>
					<CardOfCarousel workTitle='戦車のゲーム' workMediaURL='/normalImage/work/gameOfTank.webp' playLink='https://unityroom.com/games/hositukage-mu5'>
						<strong>・制作期間</strong>
						：2021/2月～2021/4月。<br>
						<strong>・概要</strong>
						：5作目として制作した、戦車を操作して敵を倒す3Dゲームです。初めてBlenderを使って3Dモデル制作に取り組み、モデリングやテクスチャ制作の基礎を学ぶきっかけになりました。
					</CardOfCarousel>

				</Carousel>
			</div>
			<div class="main-works-footer">
				<a class="link-works" href="/works">全ての作品を見る</a>
			</div>

		</section>
	</main>
</Layout>
<style>
	@import url("../styles/pages/index.scss");
</style>
