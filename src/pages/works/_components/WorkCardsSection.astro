---
interface Props {
    sectionTitle:string;
    zIndex:string;
}
const {sectionTitle,zIndex="auto"}:Props = Astro.props;
---
<work-cards-section role="section" style={`--z-index:${zIndex};`}>
    <h2>{sectionTitle}</h2>
    <div>
        <slot></slot>
    </div>
</work-cards-section>
<style lang="scss">
@use '../../../global-styles/_utility' as *;
@layer Layout{
    work-cards-section{
        z-index:var(--z-index);
        margin-top:25px;
        h2{
            display: flex;
            justify-content: center;

            position:relative;
            &::before{
                position:absolute;
                top:-15px;
                left:50%;
                transform:translateX(-50%);
            }
        }
        div{
            display:flex;
            flex-wrap:wrap;
            justify-content: center;
            gap:10px;
        }
    }
}
@layer Appearance{
    work-cards-section{
        width:calc(100% - 100px);
        h2{
            background-color: $dark-gray;
            border-top-left-radius: 40px;
            border-top-right-radius: 40px;
            padding-bottom:10px;

            color:white;
            font-size: 30px;
            font-family: sans-serif;
            &::before{
                width:300px;
                height:16px;
                background-color: $dark-gray;
                border-top-left-radius: 40px;
                border-top-right-radius: 40px;
                content: "";
            }

        }
        div{
            padding:10px;
            background-color: white;
            border:1px solid black;
        }
    }
}
@media (max-width:550px) {
    work-cards-section{
        
        width:100%;
        h2{
            &::before{
                width:200px;
            }
        }
        div{
            padding: 10px 0px;
        }
        
    }
}

</style>