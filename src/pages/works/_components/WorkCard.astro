---
//カルーセルの構成要素にならないカード、なる方のカードはWorkCardOfCarousel.astroを参照
interface Props{
	workMediaURL:string;
	workTitle:string;
	playLink?:string;
	detailLink?:string;
}
const {workMediaURL: workMediaURL,workTitle: workTitle,playLink:playLink,detailLink:detailLink}:Props = Astro.props;

//#渡されたmediaが動画か否かのチェックを行う処理
const videoExtensions:Array<string> = ['.mp4','.webm']
const isVideo:boolean = videoExtensions.some(ext => workMediaURL.endsWith(ext));
---

<work-card role="article">
	<div class="card-first-view">				
		<h3>{workTitle}</h3>
		<div class="media-container">
			{isVideo ?(
				<img class="image-background" src='/icon/MyIcon.webp'></img>
				<video src={workMediaURL} autoplay loop muted playsinline></video>
			):(
				<img class="image-background" src={workMediaURL}></img>
				<img src={workMediaURL}>
			)}
		</div>
		<p class="card-specs-wrapper">
			<slot name="card-specs"></slot>
		</p>
		<div class="link-button-wrapper">
			<a class="show-overview-button">制作談</a>
			{playLink ?(
				<a href={playLink} target="_blank" rel="noopener noreferrer">遊ぶ</a>
			):(
				<a class="is-deactive"></a>
			)}
		</div>
	</div>
	<div class="card-overview">
		<h3>{workTitle}</h3>
		<section class="overview-wrapper">
			<slot name="overview"/>
		</section>
		<div class="link-button-wrapper">
			<a class="show-first-view-button">戻る</a>
			{detailLink ?(
				<a href={detailLink} target="_blank" rel="noopener noreferrer">詳細</a>
			):(
				<a class="is-deactive"></a>
			)}
		</div>

	</div>
</work-card>	
 
<style lang="scss">
@use '../../../global-styles/_utility' as *;
@function GetSmoothShadowValue($color,$step:5px,$count:5,$offset:2px){
	$result:();
	@for $countUp from 0 to $count{
		$BottomPos:$countUp * $step + $offset;
        $blur:$countUp * $step;
		$alpha:1 - ($countUp / $count);
		$result:append($result,0 $BottomPos $blur rgba($color,$alpha),comma);
	}
	@return $result;
}

$cardWidth:355px;
@layer Layout{
	work-card{
		display:grid;
		grid-template-areas: "content";
		.card-first-view,.card-overview{
			grid-area: content;
			display: flex;
			flex-direction: column;
			align-items: center;
		}
		.card-first-view{
			h3{
				display:flex;
				align-items: center;
				justify-content: center;
			}
			.media-container{
				position:relative;
				margin-top:8px;
				.image-background{
					position:absolute;
				}
				img{
					position:absolute;
				}
				video{
					position:absolute;
				}
			}
			.card-specs-wrapper{
				margin-top:12px;
			}
			.link-button-wrapper{
				display: flex;
				flex-direction: row;
				justify-content:center;
				gap:20px;
				a{
					display:flex;
					align-items: center;
					justify-content: center;
					&:not(.is-deactive){
						&:active{
							transform:translateY(5px);
						}
					}
					&.is-deactive{
					}
				}
			}
		}
		.card-overview{
			transform:translateY(calc(-100% - 10px));
			&.is-show{
				transform:translateY(0px);
			}
			h3{
				flex-shrink: 0;
				display:flex;
				align-items: center;
				justify-content: center;
			}
			.overview-wrapper{
				flex-grow:1;
				flex-basis:0;
			}
			.link-button-wrapper{
				display: flex;
				flex-direction: row;
				justify-content:center;
				gap:20px;

				position:relative;
				//#右の青色のバーに当たる部分
				&::before{
					position:absolute;
					right:0px;
				}
				a{
					margin:7px 0px 10px 0px;
					display:flex;
					align-items: center;
					justify-content: center;

					&:not(.is-deactive){
						&:active{
							transform:translateY(5px);
						}
					}
					&.is-deactive{
					}
				}
			}
		}
	}
}
@layer Appearance{
	work-card{

		box-sizing: content-box;
		width:$cardWidth;
		padding:0px 0px 10px 0px;
		overflow:hidden;
		-webkit-tap-highlight-color: transparent;
		.card-first-view, .card-overview{
			width:$cardWidth;
		}
		.card-first-view{
			box-shadow: GetSmoothShadowValue(darkgoldenrod,2px,4,1px); 
			border:2px solid $dark-gray;
			background-color: $light-yellow;
			border-top-left-radius: 20px;	
			border-top-right-radius: 20px;			

			h3{
				width:100%;
				height: 35px;
				background-color: $yellow;
				border-top-left-radius: 18px;	
				border-top-right-radius: 18px;			


				font-size:20px;
				font-family: sans-serif;
			}
			.media-container{
				overflow: hidden;
				outline:3px solid $yellow;;
				&,& > *{
					width:$cardWidth - 25px;
					aspect-ratio: 16 / 9;	
					border-top-left-radius: 20px;	
					border-top-right-radius: 20px;			
				}
				.image-background{
					object-fit: cover;
					pointer-events: none;
					filter:blur(20px);
				}
				img{
					pointer-events: none;
					object-fit: contain;
				}
				video{

				}
			}
			.card-specs-wrapper{
				width:$cardWidth - 25px;
				height:100px;
				padding:2px 5px;

				outline:3px solid $yellow;
				border-bottom-left-radius: 20px;	
				border-bottom-right-radius: 20px;			
				background-color: white;			
			}

			.link-button-wrapper{
				width:100%;
				padding:10px 0px;
				a{
					width:100px;
					height:30px;
					user-select: none;
					border-radius: 30px;
					background-color: $yellow;
					box-shadow: 0 5px 0 $dark-yellow;
					user-select: none;
					&:not(.is-deactive){
						font-family: sans-serif;
						&:active{
							box-shadow: 0 0 0 $dark-yellow;
						}
						&:hover{
							cursor: pointer; 
						}
					}
					&.is-deactive{
						background-color: rgba($yellow,0.6);
						box-shadow: 0 5px 0 rgba($dark-yellow,0.6);
						cursor: not-allowed;
					}
				}
			}
		}
		.card-overview{
			transition:transform 0.5s;
			will-change: transform;
			box-shadow: GetSmoothShadowValue($dark-blue,2px,4,1px); 
			background-color: $light-blue;

			border:2px solid $dark-gray;
			border-top-left-radius: 20px;	
			border-top-right-radius: 20px;			
			h3{
				width:100%;
				height:35px;
				background-color: $blue;
				border-top-left-radius: 18px;	
				border-top-right-radius: 18px;			

				color:white;
				font-size:20px;
				font-family: sans-serif;
			}
			.overview-wrapper{
				width:100%;
				background-color: whitesmoke;
				color:black;
				&::-webkit-scrollbar{
					width:10px;
				}
				&::-webkit-scrollbar-track{
					background-color: $blue;
				}
				&::-webkit-scrollbar-thumb{
					background-color: $light-blue;
					border-radius: 8px;
					border-right:3px solid $blue;
					border-left:3px solid $blue;
				}
				overflow-y: scroll;
				overflow-x: hidden;

				line-height:1.5;
				padding:2px 5px;
				font-size:16px;
				font-family: serif;
				line-break: anywhere;
			}
			.link-button-wrapper{
				width:100%;
				border-top:3px solid $blue;
				border-right:10px solid $blue;

				a{
					width:100px;
					height:30px;
					background-color: $blue;
					box-shadow: 0 5px 0 $dark-blue;
					border-radius: 30px;
					user-select: none;
					color:whitesmoke;
					user-select: none;
					isolation: isolate;
					&:not(.is-deactive){
						font-family: sans-serif;
						&:active{
							box-shadow: 0 0 0 $dark-yellow;
						}
						&:hover{
							cursor: pointer; 
						}
					}
					&.is-deactive{
						background-color: rgba($blue,0.6);
						box-shadow: 0 5px 0 rgba($dark-blue,0.6);
						cursor: not-allowed;
					}
				}	
			}
		}
	}
}

@media (max-width:700px) {
}
</style>  
<script>
	class WorkCard extends HTMLElement{
		connectedCallback(){
			//#Cardとしての役割を果たせるかのチェック
			const showFirstViewButton:HTMLElement|null = this.querySelector('.show-first-view-button');
			if(showFirstViewButton===null){console.error('show-first-view-buttonクラス属性が付与されたhtml要素が見つかりませんでした。'); 
				return;}
			const showOverviewButton:HTMLElement|null = this.querySelector('.show-overview-button');
			if(showOverviewButton===null){console.error('show-overview-buttonクラス属性が付与されたhtml要素が見つかりませんでした');
				return;}
			const cardOverview :HTMLElement|null = this.querySelector('.card-overview');
			if(cardOverview===null){console.error('card-overviewクラス属性が付与されたhtml要素が見つかりませんでした');
				return;}
			//#メインとなる処理
			console.log("関数の購読を開始します。");
			//##関数の購読
			showFirstViewButton.addEventListener('click',()=>{
				cardOverview.classList.remove('is-show')
			});
			showOverviewButton.addEventListener('click',()=>{
				console.log("showOverviewButtonが押されました");
				cardOverview.classList.add('is-show')
			})
		}
	}
	customElements.define('work-card',WorkCard);

</script>


