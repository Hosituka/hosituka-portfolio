---
//ここは全てのBlog以外のwebページにおいて、共通する内容を書くところです。cssレイヤーの都合から各ページコンポーネントのフロントマターで一番最初に読み込んでください
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title:string;
}

const {title}:Props = Astro.props;

---
<!doctype html>		
<html lang="ja">	
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<style is:inline>
			@layer Normalize, CssReset, Layout, Appearance;
		</style>
	</head>
	<body>
		<Navigation/>	
		<slot />
		<Footer zIndex='2' blendMode='multiply'/>
	</body>
</html>

<style is:global lang="scss">
/*##ユーザーエージェントスタイルシートを統一するスタイルシートをlayerとして読み込んでいる、*/
@import url("../styles/Normalize.css") layer(Normalize);
/*##webページ全体で共通するスタイルをレイヤーとして読み込んでいる*/
@import url("../styles/CssReset.css") layer(CssReset);

@layer Layout{
	body{
		position:relative;
		display:flex;
		flex-direction: column;
		min-height:100dvh;
		main{
			position:relative;
		}
	}
	
}
@layer Appearance{
	
	html {
		font-size:100%;
		
		//#ios特有のびよーんってなってもとにもどる挙動を防ぐコード
		 overscroll-behavior: none;
		body{
			overscroll-behavior: none;
			main{
				flex-grow:1;
			}
		}
	}
}
