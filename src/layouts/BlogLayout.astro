---
//ここは全てのBlog系のwebページにおいて、共通する内容を書くところです。cssレイヤーの都合から各ページコンポーネントのフロントマターで一番最初に読み込んでください
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title:string;
}

const {title}:Props = Astro.props;

---
<!doctype html>		
<html lang="ja">	
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<style is:inline>
			@layer Normalize, CssReset, Layout, Appearance;
		</style>

	</head>
	<body>
        <Navigation/>
		<div class="blog-wrapper">
			
			<slot/>
		</div>
		<Footer zIndex='2' blendMode='multiply'/>
	</body>
</html>

<style is:global lang="scss">
@use "../styles/_utility" as *;
/*##ユーザーエージェントスタイルシートを統一するスタイルシートをlayerとして読み込んでいる、*/
@import url("../styles/Normalize.css") layer(Normalize);
/*##webページ全体で共通するスタイルをレイヤーとして読み込んでいる*/
@import url("../styles/CssReset.css") layer(CssReset);


@layer Layout{
	body{
		position:relative;
		display:flex;
		align-items:center;
		flex-direction: column;
		min-height:100dvh;
        .blog-wrapper{
            position:relative;
			margin-top:70px;
			margin-bottom:20px;
			header{
				position:relative;
				display:flex;
				flex-direction:column;
				gap:5px;
				h1{
				}
				.tag-wrapper{
					display:flex;
					flex-wrap:wrap;
					gap:10px;
				}
			}
			main{
				position:relative;
			}
        }
	}
}
@layer Appearance{
	
	html {
		//#ios特有のびよーんってなってもとにもどる挙動を防ぐコード
		overscroll-behavior: none;
		body{
			overscroll-behavior: none;
            background-image: linear-gradient(to bottom,
                    $light-yellow,$light-yellow 200px,
                    gray 200px, gray 201px,
                    ghostwhite 201px, ghostwhite 100%);

            .blog-wrapper{
                width:1000px;
				flex-grow:1;
                background-color: white;
                box-shadow:0px 0px 6px gray;
				@media(max-width:1020px){
					width:calc(100% - 20px);
				}
				header{
					width:100%;
					padding:10px 20px;
					background-color:$yellow;
					border-bottom:1px solid gray;
					h1{
						font-weight: 900;
						font-size:50px;
						color: white;
						-webkit-text-stroke-width: 1px;
						-webkit-text-stroke-color: black;
						paint-order: stroke fill;
						font-family:"Noto Sans JP" , sans-serif;
						overflow-wrap:anywhere;
						/** */
					}
					.tag-wrapper{
						.tag{
							background-color:white;
							outline:1px solid gray;
							padding:2px 20px;
							border-radius:5px;
						}
					}
				}
				main{
					padding:10px;
					font-size:30px;
				}
				@media(max-width:700px){
					header{
						padding:10px;
						h1{
							font-size:30px;
						}
					}
					main { 
						font-size:25px;
					}
				}
            }
		}
	}
}

