---
//#グローバルナビゲーションに関するアストロファイル
export interface Props {
    topURL:string;
    worksURL:string;
    devLogURL:string;
    sNS_URL:string;
}

const { topURL, worksURL, devLogURL, sNS_URL }:Props = Astro.props;
---
<!-- ##グローバルナビゲーションの要素ノード-->
<nav>
    <ul>
        <li><a href={topURL}>ホーム</a></li>
        <li><a href={worksURL}>作品</a></li>
        <li><a href={devLogURL}>開発日誌</a></li>
        <li><a href={sNS_URL}>SNS</a></li>
    </ul>
</nav>
<!-- ##グローバルナビゲーションのスタイル-->
<style lang="scss">
@use '../global-styles/_variables' as *;
@layer Layout{
	nav {
		position: fixed;
		z-index: 1000;
		top: 0px;
		ul {
			margin: 0px;
			display: flex;
			justify-content: space-around;
			align-items: center;
			li{
				a {
					display: block;
				}
			}
		}
	}
}
@layer Appearance{
    nav {
		width: 100%;
		height: 50px;
		opacity: 0.9;
		background-color: $dark-gray;
		border-bottom: 2px solid black;
		border-bottom-left-radius: 40px;
		border-bottom-right-radius: 40px;
		ul{
			width: 100%;
			height: 100%;
			list-style: none;
			li{
				a{
					font-size: 20px;
					font-family: sans-serif;
					color: white;
					padding: 10px 0px 10px 0px; /* PC表示でのpaddingを少し調整 */
					text-decoration: none;
					transition: background-color 0.3s;
				}
				a:hover{
					background-color: #555;
				}
			}
		}
	}
}
@media (max-width:790px) {
}

</style>
