---
//#グローバルナビゲーションに関するアストロファイル
function isActive(path:string):boolean{
	const pathname = Astro.url.pathname;
	switch(pathname){
		case path:
			return true;
		case path + '/':
			return true;
		default:
			return false;
	}
}

const topURL:string = "/";
const aboutMeURL:string = "/aboutMe/aboutMe"
const worksURL:string =  "/works/works";
const devLogURL:string = "/devLog/devLog";
---
<!-- ##グローバルナビゲーションの要素ノード-->
<nav>
	<div class="link-buttons">
		<a href={topURL} class:list={[{"is-current":isActive(topURL)}]}>ホーム</a>
		<a href={aboutMeURL} class:list={[{"is-current":isActive(aboutMeURL)}]}>自己紹介</a>
		<a href={worksURL} class:list={[{"is-current":isActive(worksURL)}]}>作品</a>
		<a href={devLogURL} class:list={[{"is-current":isActive(devLogURL)}]}>日誌</a>
	</div>
</nav>
<!-- ##グローバルナビゲーションのスタイル-->
<style lang="scss">
@use '../global-styles/_utility' as *;
@layer Layout{
	nav {
		position: fixed;
		z-index: 1000;
		top: 0px;
		.link-buttons{
			margin: 0px;
			display: flex;
			justify-content: space-around;
			align-items: center;
			a {				
				position:relative;
				display: flex;
				justify-content: center;
				align-items: center;
				&::after{
					position:absolute;
					bottom:7px;
					left:50%;
					transform:translateX(-50%);
				}
			}
		}
	}
}
@layer Appearance{
    nav {
		width: 100%;
		height: 50px;
		.link-buttons{
			width: 100%;
			height: 100%;
			a{
				width: 100%;
				height:100%;
				background-color: $dark-gray;
				opacity: 0.9;
				border-top: 1px solid gray;
				border-left: 0.5px solid gray;
				border-bottom: 1px solid gray;
				border-right: 0.5px solid gray;

				font-size: 20px;
				text-align: center;
				font-family: sans-serif;
				color: white;
				text-decoration: none;
				white-space:nowrap;
				&::after{
					width:0%;
					height:3px;
					background-color: white;
					content:"";
					transition:width 0.3s ease-out;
				}
				&:hover::after{
					width:90%;
				}
			}
			a.is-current{
				background-color: gray;
				border-bottom: 1px solid black;

				color:black;
				&::after{
					background-color: black;
				}
			}
		}
	}
}
@media (max-width:790px) {
}

</style>
