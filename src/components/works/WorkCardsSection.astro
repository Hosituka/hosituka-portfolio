---
interface Props {
    sectionTitle:string;
    zIndex:string;
}
const {sectionTitle,zIndex="auto"}:Props = Astro.props;
---
<work-cards-section role="region" style={`--z-index:${zIndex};`}>
    <h2>{sectionTitle}</h2>
    <div>
        <slot></slot>
    </div>
</work-cards-section>
<style lang="scss">
@use '../../styles/utility' as *;
$gap:20px;
@layer Layout{
    work-cards-section{
        z-index:var(--z-index);
        margin-top:25px;
        h2{
            display: flex;
            justify-content: center;

            position:relative;
            &::before{
                position:absolute;
                top:-15px;
                left:50%;
                transform:translateX(-50%);
            }
        }
        div{
            gap:$gap;
            display:flex;
            justify-content: center;
            flex-wrap:wrap;

        }
    }
}
@layer Appearance{
    work-cards-section{
        width:calc(100% - 100px);
        h2{
            background-color: $dark-gray;
            border-top-left-radius: 40px;
            border-top-right-radius: 40px;
            padding-bottom:10px;

            color:white;
            font-size: 30px;
            font-family: sans-serif;
            &::before{
                width:300px;
                height:16px;
                background-color: $dark-gray;
                border-top-left-radius: 40px;
                border-top-right-radius: 40px;
                content: "";
            }

        }
        div{
            padding:20px 20px;
            background-color: white;
            border:1px solid black;
            :global(work-card){
                flex: 0 0 calc((100% - (2*$gap)) / 3);
            }

        }
    }
}
@media (max-width:1100px) {
	work-cards-section{
        div{
            :global(work-card){
                flex: 0 0 calc((100% - $gap) / 2);
            }
        }
	}
}
@media (max-width:750px) {
	work-cards-section{
        div{
            :global(work-card){
                flex: 0 0 100%;
            }
        }
	}
}

@media (max-width:550px) {
    work-cards-section{
        
        width:100%;
        h2{
            &::before{
                width:200px;
            }
        }
        div{
            padding: 10px 10px;
        }
        
    }
}

</style>