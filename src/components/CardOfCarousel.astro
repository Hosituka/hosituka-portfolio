---
//#各作品を紹介するカード
---

<card-of-carousel>
	<div class="card">
		<div class="card-overview">				
			<h3>ほしつか</h3>
			<img src="/Icon/MyIcon.webp" alt="ほしつかのアイコン">
			<div class="link-buttons">
				<a class="show-teck-info-button">技術</a>
				<a>遊ぶ</a>
			</div>
		</div>
		<div class="card-teck-info">
			<h3>使用技術</h3>
			<ul>
				<li>UnityとC#</li>
				<li>ShaderGraph</li>
				<li>HTMLとCSS</li>
				<li>UnityとC#</li>
				<li>ShaderGraph</li>
				<li>HTMLとCSS</li>
				<li>UnityとC#</li>
				<li>ShaderGraph</li>
				<li>HTMLとCSS</li>
				<li>UnityとC#</li>
				<li>ShaderGraph</li>
				<li>HTMLとCSS</li>
			</ul>
			<div class="link-buttons">
				<a class="show-overview-button">戻る</a>
				<a>詳細</a>
			</div>

		</div>
	</div>
</about-me-card>	
 
<style lang="scss">
@use '../global-styles/_variables' as *;
@layer Layout{
	card-of-carousel{
		perspective: 2000px;
		.card{
			transform-style:preserve-3d;
			position:relative;
			.card-overview,.card-teck-info{
				position:absolute;
			}
			.card-overview{
				display: flex;
				flex-direction: column;
				align-items: center;
				img{
					margin-top:5px;
				}
				.link-buttons{
					margin-top: 5px;
					display: flex;
					flex-direction: row;
					justify-content:center;
					gap:20px;
					a{
						&:active{
							transform:translateY(5px);
						}
					}
				}
			}
			.card-teck-info{
				transform:translateY(-225px);
				display: flex;
				flex-direction: column;
				align-items: center;
				&.is-show{
					transform:translateY(0px);
				}

				ul{
					display:flex;
					flex-wrap:wrap;
					gap:5px;
					li{
						display:flex;
						flex-direction: row;
						align-items: center;
					}
				}
				.link-buttons{
					margin-top: 5px;
					display: flex;
					flex-direction: row;
					justify-content:center;
					gap:20px;
					a{
						&:active{
							transform:translateY(5px);
						}
					}
				}
			}
		}
	}
}
@layer Appearance{
	card-of-carousel{
		.card{
			width: 250px;
			height:215px;
			-webkit-tap-highlight-color: transparent;
			overflow: hidden;
			.card-overview, .card-teck-info{
				width:100%;
				height:100%;
				.back-ground, .content{
					width:100%;
					height:100%;
				}
			}
			.card-overview{
				box-shadow: 4px 4px 8px darkgoldenrod; 
				border:2px solid $yellow;
				background-color: $light-yellow;
				h3{
					width:100%;
					line-height: 35px;
					background-color: $yellow;
					text-align: center;
					font-size:20px;
					font-family: sans-serif;
				}
				img{
					background-image: url('texture/simpleNoise.webp');
					width:225px;
					aspect-ratio: 16 / 9;
					border-radius: 20px;
					object-fit: contain;
					border:3px solid $yellow;;
				}
				.link-buttons{
					width:calc(100% - 15px);
					a{
						background-color: $yellow;
						box-shadow: 0 5px 0 $dark-yellow;
						text-align: center;
						font-family: sans-serif;
						line-height:30px;
						width:100px;
						border-radius: 30px;
						&:active{
							box-shadow: 0 0 0 $dark-yellow;
						}
					}
					
				}
			}
			.card-teck-info{
				transition:transform 0.5s;
				will-change: transform;
				box-shadow: 4px 4px 8px darkblue; 
				background-color: $light-blue;
				border:2px solid $blue;;
				h3{
					width:100%;
					line-height: 35px;
					background-color: $blue;
					text-align: center;
					font-size:20px;
					font-family: sans-serif;
				}
				ul{
					li{
						list-style:none;
						font-size:15px;
						font-family: serif;
						&::before{
							font-weight: 900;
							content: '・';
							color :black;
						}
					}
				}
				.link-buttons{
					width:calc(100% - 15px);
					a{
						background-color: $blue;
						box-shadow: 0 5px 0 $dark-blue;
						text-align: center;
						font-family: sans-serif;
						line-height:30px;
						width:100px;
						border-radius: 30px;
						&:active{
							box-shadow: 0 0 0 $dark-blue;
						}
					}	
				}
			}
		}
	}
}

@media (max-width:700px) {
	card-of-carousel{
	}
}
    

</style>
<script>
	class CardOfCarousel extends HTMLElement{
		connectedCallback(){
			const showTeckInfoButton:Element|null = this.querySelector('.show-teck-info-button');
			if(showTeckInfoButton===null){console.error('show-teck-info-buttonクラス属性が付与されたhtml要素が見つかりませんでした。'); 
				return;}

			const showOverviewButton:Element|null = this.querySelector('.show-overview-button');
			if(showOverviewButton===null){console.error('show-overview-buttonクラス属性が付与されたhtml要素が見つかりませんでした');
				return;}

			const cardTeckInfo :Element|null = this.querySelector('.card-teck-info');
			if(cardTeckInfo===null){console.error('card-teck-infoクラス属性が付与されたhtml要素が見つかりませんでした');
				return;}

			showTeckInfoButton.addEventListener('click',()=>{
				cardTeckInfo.classList.add('is-show');
			});
			showOverviewButton.addEventListener('click',()=>{
				cardTeckInfo.classList.remove('is-show');
			})

		}
	}
	customElements.define('card-of-carousel',CardOfCarousel);

</script>
