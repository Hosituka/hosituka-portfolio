---
//#各作品を紹介するカード
interface Props{
	workImageURL:string;
	workTitle:string;
}
const {workImageURL,workTitle}:Props = Astro.props;
---

<card-of-carousel data-work-title={workTitle}>
	<div class="card">
		<div class="card-info">				
			<h3>{workTitle}</h3>
			<div class="image-container">
				<div class="image-background"></div>
				<img src={workImageURL} alt="ほしつかのアイコン">
			</div>
			<div class="link-buttons">
				<a class="show-overview-button">概要</a>
				<a>遊ぶ</a>
			</div>
		</div>
		<div class="card-overview">
			<h3>{workTitle}:概要</h3>
			<p>
				<slot />
			</p>
			<div class="link-buttons">
				<a class="show-info-button">戻る</a>
				<a>詳細</a>
			</div>

		</div>
	</div>
</card-of-carousel>	
 
<style lang="scss" define:vars={{workImageURL:`url("${workImageURL}")`}}>
@use '../global-styles/_variables' as *;
$cardWidth:300px;
$cardHeight:245px;
@layer Layout{
	card-of-carousel{
		perspective: 2000px;
		.card{
			transform-style:preserve-3d;
			position:relative;
			.card-info,.card-overview{
				position:absolute;
			}
			.card-info{
				display: flex;
				flex-direction: column;
				align-items: center;
				.image-container{
					position:relative;
					margin-top:8px;
					.image-background{
						position:absolute;
					}
					img{
						position:absolute;
					}
				}
				.link-buttons{
					margin-top: 8px;
					display: flex;
					flex-direction: row;
					justify-content:center;
					gap:20px;
					a{
						&:active{
							transform:translateY(5px);
						}
					}
				}
			}
			.card-overview{
				transform:translateY(-$cardHeight - 10px);
				display: flex;
				flex-direction: column;
				align-items: center;
				&.is-show{
					transform:translateY(0px);
				}
				.link-buttons{
					margin-top: 5px;
					display: flex;
					flex-direction: row;
					justify-content:center;
					gap:20px;
					a{
						&:active{
							transform:translateY(5px);
						}
					}
				}
			}
		}
	}
}
@layer Appearance{
	card-of-carousel{
		.card{
			width: $cardWidth + 8px;
			height:$cardHeight + 8px;
			overflow:hidden;
			-webkit-tap-highlight-color: transparent;
			user-select: none;
			.card-info, .card-overview{
				width:$cardWidth;
				height:$cardHeight;
				.back-ground, .content{
					width:100%;
					height:100%;
				}
			}
			.card-info{
				box-shadow: 4px 4px 8px darkgoldenrod; 
				border:2px solid $yellow;
				background-color: $light-yellow;
				h3{
					width:100%;
					line-height: 35px;
					background-color: $yellow;
					text-align: center;
					font-size:20px;
					font-family: sans-serif;
				}
				.image-container{
					overflow: hidden;
					outline:3px solid $yellow;;
					&,& > *{
						width:$cardWidth - 35px;
						aspect-ratio: 16 / 9;	
						border-radius: 20px;				
					}
					.image-background{
						object-fit: cover;
						background-image: var(--workImageURL);
						filter:blur(20px);
					}
					img{
						object-fit: contain;
						-webkit-user-drag: none;
					}
				}
				.link-buttons{
					width:calc(100% - 15px);
					a{
						background-color: $yellow;
						box-shadow: 0 5px 0 $dark-yellow;
						text-align: center;
						font-family: sans-serif;
						line-height:30px;
						width:100px;
						user-select: none;
						border-radius: 30px;
						&:active{
							box-shadow: 0 0 0 $dark-yellow;
						}
						&:hover{
							cursor: pointer; 
						}
					}
					
				}
			}
			.card-overview{
				transition:transform 0.5s;
				will-change: transform;
				box-shadow: 4px 4px 8px darkblue; 
				background-color: $light-blue;
				border:2px solid $blue;;
				h3{
					width:100%;
					line-height: 35px;
					background-color: $blue;
					text-align: center;
					font-size:20px;
					font-family: sans-serif;
				}
				p{
					width:100%;
					height:$cardHeight - 85px;
					padding:0px 5px;
					font-size:20px;
					font-family: serif;
					overflow-wrap:break-word;
				}
				.link-buttons{
					width:calc(100% - 15px);
					a{
						background-color: $blue;
						box-shadow: 0 5px 0 $dark-blue;
						text-align: center;
						font-family: sans-serif;
						line-height:30px;
						width:100px;
						border-radius: 30px;
						user-select: none;
						&:active{
							box-shadow: 0 0 0 $dark-blue;
						}
						&:hover{
							cursor: pointer; 
						}
					}	
				}
			}
		}
	}
}

@media (max-width:700px) {
	card-of-carousel{
	}
}
    

</style>
<script>
	class CardOfCarousel extends HTMLElement{
		connectedCallback(){
			//#Cardとしての役割を果たせるかのチェック
			const showInfoButton:Element|null = this.querySelector('.show-info-button');
			if(showInfoButton===null){console.error('show-info-buttonクラス属性が付与されたhtml要素が見つかりませんでした。'); 
				return;}

			const showOverviewButton:Element|null = this.querySelector('.show-overview-button');
			if(showOverviewButton===null){console.error('show-overview-buttonクラス属性が付与されたhtml要素が見つかりませんでした');
				return;}

			const cardOverview :Element|null = this.querySelector('.card-overview');
			if(cardOverview===null){console.error('card-overviewクラス属性が付与されたhtml要素が見つかりませんでした');
				return;}
			const title:string|undefined = this.dataset.workTitle;
			if(title===undefined){console.error('data-work-titleが指定されていません。')
				return;}

			//#メインとなる処理
			//##関数の購読
			showInfoButton.addEventListener('click',()=>{
				this.dispatchEvent(new CustomEvent('sync-card-state',{
					bubbles:true,
					detail:{title:title,isShow:false}
				}));
			});
			showOverviewButton.addEventListener('click',()=>{
				this.dispatchEvent(new CustomEvent('sync-card-state',{
					bubbles:true,
					detail:{title:title,isShow:true}
				}));

			})

			window.addEventListener('update-card-ui',(e:any) =>{
				if(e.detail.title !== title){return};
				
				if(e.detail.isShow){
					cardOverview.classList.add('is-show')
				}
				else{
					cardOverview.classList.remove('is-show')
				}
			})
		}
	}
	customElements.define('card-of-carousel',CardOfCarousel);

</script>
