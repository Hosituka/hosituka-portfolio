---

interface Props{
	workMediaURL:string;
	workTitle:string;
	playLink?:string;
	detailLink?:string;
}
const {workMediaURL: workMediaURL,workTitle: workTitle,playLink:playLink,detailLink:detailLink}:Props = Astro.props;

//#渡されたmediaが動画か否かのチェックを行う処理
const videoExtensions:Array<string> = ['.mp4','.webm']
const isVideo:boolean = videoExtensions.some(ext => workMediaURL.endsWith(ext));
---

<work-card-of-carousel data-work-title={workTitle}>
	<div class="card">
		<div class="card-info">				
			<h3>{workTitle}</h3>
			<div class="media-container">
				{isVideo ?(
					<img class="image-background" src='icon/MyIcon.webp'></img>
					<video src={workMediaURL} autoplay loop muted playsinline></video>
				):(
					<img class="image-background" src={workMediaURL}></img>
					<img src={workMediaURL} alt="ほしつかのアイコン">
				)}
			</div>
			<div class="link-buttons">
				<a class="show-overview-button">概要</a>
				{playLink ?(
					<a href={playLink}>遊ぶ</a>
				):(
					<a class="is-deactive"></a>
				)}
			</div>
		</div>
		<div class="card-overview">
			<h3>{workTitle}:概要</h3>
			<p>
				<slot />
			</p>
			<div class="link-buttons">
				<a class="show-info-button">戻る</a>
				{detailLink ?(
					<a href={detailLink}>詳細</a>
				):(
					<a class="is-deactive"></a>
				)}
			</div>

		</div>
	</div>
</work-card-of-carousel>	
 
<style lang="scss">
@use '../global-styles/_variables' as *;
$cardWidth:300px;
$cardHeight:245px;
@layer Layout{
	work-card-of-carousel{
		perspective: 2000px;
		.card{
			transform-style:preserve-3d;
			position:relative;
			.card-info,.card-overview{
				position:absolute;
			}
			.card-info{
				display: flex;
				flex-direction: column;
				align-items: center;
				.media-container{
					position:relative;
					margin-top:8px;
					.image-background{
						position:absolute;
					}
					img{
						position:absolute;
					}
					video{
						position:absolute;
					}
				}
				.link-buttons{
					margin-top: 10px;
					display: flex;
					flex-direction: row;
					justify-content:center;
					gap:20px;
					a{
						&:not(.is-deactive){
							&:active{
								transform:translateY(5px);
							}
						}
						&.is-deactive{
						}
					}
				}
			}
			.card-overview{
				transform:translateY(-$cardHeight - 10px);
				display: flex;
				flex-direction: column;
				align-items: center;
				&.is-show{
					transform:translateY(0px);
				}
				.link-buttons{
					margin-top: 5px;
					display: flex;
					flex-direction: row;
					justify-content:center;
					gap:20px;
					a{
						&:active{
							transform:translateY(5px);
						}
					}
				}
			}
		}
	}
}
@layer Appearance{
	work-card-of-carousel{
		.card{
			width: $cardWidth + 8px;
			height:$cardHeight + 8px;
			overflow:hidden;
			-webkit-tap-highlight-color: transparent;
			user-select: none;
			.card-info, .card-overview{
				width:$cardWidth;
				height:$cardHeight;
				.back-ground, .content{
					width:100%;
					height:100%;
				}
			}
			.card-info{
				box-shadow: 4px 4px 8px darkgoldenrod; 
				border:2px solid $yellow;
				background-color: $light-yellow;
				h3{
					width:100%;
					line-height: 35px;
					background-color: $yellow;
					text-align: center;
					font-size:20px;
					font-family: sans-serif;
				}
				.media-container{
					overflow: hidden;
					outline:3px solid $yellow;;
					&,& > *{
						width:$cardWidth - 35px;
						aspect-ratio: 16 / 9;	
						border-radius: 20px;				
					}
					.image-background{
						object-fit: cover;
						pointer-events: none;
						filter:blur(20px);
					}
					img{
						pointer-events: none;
						object-fit: contain;
					}
					video{

					}
				}
				.link-buttons{
					width:calc(100% - 15px);
					a{
						width:100px;
						user-select: none;
						border-radius: 30px;
						background-color: $yellow;
						box-shadow: 0 5px 0 $dark-yellow;
						user-select: none;
						&:not(.is-deactive){
							text-align: center;
							font-family: sans-serif;
							line-height:30px;
							&:active{
								box-shadow: 0 0 0 $dark-yellow;
							}
							&:hover{
								cursor: pointer; 
							}
						}
						&.is-deactive{
							opacity: 0.5;
							cursor: not-allowed;
						}
					}
				}
			}
			.card-overview{
				transition:transform 0.5s;
				will-change: transform;
				box-shadow: 4px 4px 8px darkblue; 
				background-color: $light-blue;
				border:2px solid $blue;;
				h3{
					width:100%;
					line-height: 35px;
					color:whitesmoke;
					background-color: $blue;
					text-align: center;
					font-size:20px;
					font-family: sans-serif;
				}
				p{
					width:100%;
					height:$cardHeight - 83px;
					line-height:20px;
					padding:2px 5px;
					font-size:16px;
					font-family: serif;
					overflow-wrap:break-word;
					
				}
				.link-buttons{
					width:calc(100% - 15px);
					a{
						background-color: $blue;
						box-shadow: 0 5px 0 $dark-blue;
						width:100px;
						border-radius: 30px;
						user-select: none;
						color:whitesmoke;
						user-select: none;
						&:not(.is-deactive){
							text-align: center;
							font-family: sans-serif;
							line-height:30px;
							&:active{
								box-shadow: 0 0 0 $dark-yellow;
							}
							&:hover{
								cursor: pointer; 
							}
						}
						&.is-deactive{
							opacity: 0.5;
							cursor: not-allowed;
						}
					}	
				}
			}
		}
	}
}

@media (max-width:700px) {
	card-of-carousel{
	}
}
    

</style>
<script>
	class WorkCardOfCarousel extends HTMLElement{
		connectedCallback(){
			//#Cardとしての役割を果たせるかのチェック
			const showInfoButton:Element|null = this.querySelector('.show-info-button');
			if(showInfoButton===null){console.error('show-info-buttonクラス属性が付与されたhtml要素が見つかりませんでした。'); 
				return;}

			const showOverviewButton:Element|null = this.querySelector('.show-overview-button');
			if(showOverviewButton===null){console.error('show-overview-buttonクラス属性が付与されたhtml要素が見つかりませんでした');
				return;}

			const cardOverview :Element|null = this.querySelector('.card-overview');
			if(cardOverview===null){console.error('card-overviewクラス属性が付与されたhtml要素が見つかりませんでした');
				return;}
			const title:string|undefined = this.dataset.workTitle;
			if(title===undefined){console.error('data-work-titleが指定されていません。')
				return;}

			//#メインとなる処理
			//##関数の購読
			showInfoButton.addEventListener('click',()=>{
				this.dispatchEvent(new CustomEvent('sync-card-state',{
					bubbles:true,
					detail:{title:title,isShow:false}
				}));
			});
			showOverviewButton.addEventListener('click',()=>{
				this.dispatchEvent(new CustomEvent('sync-card-state',{
					bubbles:true,
					detail:{title:title,isShow:true}
				}));

			})

			window.addEventListener('update-card-ui',(e:any) =>{
				if(e.detail.title !== title){return};
				
				if(e.detail.isShow){
					cardOverview.classList.add('is-show')
				}
				else{
					cardOverview.classList.remove('is-show')
				}
			})
		}
	}
	customElements.define('work-card-of-carousel',WorkCardOfCarousel);

</script>
