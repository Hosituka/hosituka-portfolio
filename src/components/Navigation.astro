---
//#グローバルナビゲーションに関するアストロファイル
function isActive(path:string):boolean{
	const pathname = Astro.url.pathname;
	switch(pathname){
		case path:
			return true;
		case path + '/':
			return true;
		default:
			return false;
	}
}

const topURL:string = "/";
const aboutMeURL:string = "/aboutMe"
const worksURL:string =  "/works";
const devLogURL:string = "/blog";
---
<!-- ##グローバルナビゲーションの要素ノード-->
<my-nav role="navigation">
	<div class="nav-links">
		<a href={topURL} class:list={[{"is-current":isActive(topURL)}]}>ホーム</a>
		<a href={aboutMeURL} class:list={[{"is-current":isActive(aboutMeURL)}]}>自己紹介</a>
		<a href={worksURL} class:list={[{"is-current":isActive(worksURL)}]}>作品</a>
		<a href={devLogURL} class:list={[{"is-current":isActive(devLogURL)}]}>日誌</a>
	</div>
	<button class="humburger-button">
		<span class="bar1"></span>
		<span class="bar2"></span>
		<span class="bar3"></span>
	</button>
</my-nav>
<!-- ##グローバルナビゲーションのスタイル-->
<style lang="scss">
@use '../styles/_utility' as *;
@layer Layout{
	my-nav {
		position: fixed;
		z-index: 1000;
		top: 0px;
		.nav-links{
			position:relative;
			margin: 0px;
			display: flex;
			justify-content: space-around;
			align-items: center;
			a {				
				position:relative;
				display: flex;
				justify-content: center;
				align-items: center;
				&::after{
					position:absolute;
					bottom:7px;
					left:50%;
					transform:translateX(-50%);
				}
			}
		}
		.humburger-button{
			position:absolute;
			top:0px;
			right:20px;
			display:none;
			& > * {
				transform-origin: center;
				position:absolute;
				left:0px;
			}
			.bar1{
				transform:translateY(-15px);
			}
			.bar2{
				transform:translateY(-3px);
			}
			.bar3{
				transform:translateY(9px);
			}
		}
	}
}
@layer Appearance{
    my-nav {
		width: 100dvw;
		height:auto;
		opacity: 0.9;
		background-color: $dark-gray;

		.nav-links{
			width: 100%;

			a{
				width: 25%;
				height:50px;
				background-color: $dark-gray;
				opacity: 0.9;
				border-bottom: 1px solid gray;

				font-size: 1.5rem;
				font-family: sans-serif;
				color: white;
				text-decoration: none;
				white-space:nowrap;
				&:not(:last-child){
					border-right: 1px solid gray;
				}

				&::after{
					width:0%;
					height:3px;
					background-color: white;
					content:"";
					transition:width 0.3s ease-out;
				}
				&:hover::after{
					width:90%;
				}
			}
			a.is-current{
				background-color: gray;
				border-bottom: 1px solid black;

				color:black;
				&::after{
					background-color: black;
				}
			}
		}
		.humburger-button{
			width:40px;
			height:50px;
			border:none;
			padding:0px;
			background-color: transparent;
			& > * {
				width:100%;
				height:5px;
				background-color: white;
			}
			.bar1{
				transition:transform 0.3s ease-out;}
			.bar2{
				transition:opacity 0.3s ease-out;}
			.bar3{
				transition:transform 0.3s ease-out;}
		}
	}
}
@media (max-width:790px) {
	my-nav{
		height:50px;
		overflow-y: hidden;
		transition:height 0.3s ease-in-out; 
		border-bottom: 2px solid white;
		.nav-links{
			padding-top:50px;
			flex-direction: column;
			left:calc(-1 * 100dvw);
			transition:transform 0.3s ease-in-out;
			a{
				display: flex;
				width:100%;
				border:none;
				&:first-child{
					border-top:1px solid white;
				}
				&:not(:last-child){
					border-bottom:1px solid white;
				}
			}
		}
		.humburger-button{
			display:block;
		}
	}
	my-nav.open-humburger{
		height:var(--nav-links-height);
		.humburger-button{
			.bar1{
				transform:translateY(-3px) rotateZ(45deg);
			}
			.bar2{
				opacity:0;
			}
			.bar3{
				transform:translateY(-3px) rotateZ(-45deg);
			}
		}
		.nav-links{
			height:auto;
			display:flex;
			transform:translateX(100dvw);
		}
	}
}
</style>
<script>
class Navigation extends HTMLElement{
    connectedCallback(){
        requestAnimationFrame(this.#Start);
    }
    #Start=() =>{
        const openHumburgerButton:HTMLElement|null = this.querySelector(".humburger-button");
        if(!openHumburgerButton){console.error(".humburger-buttonが見つかりません");return;}
        const navLinks:HTMLElement|null = this.querySelector(".nav-links");
        if(!navLinks){console.error(".nav-linksが見つかりません");return;}

        this.style.setProperty('--nav-links-height',`${navLinks.scrollHeight}px`);

        const resizeObserver = new ResizeObserver(()=>{
            this.style.setProperty('--nav-links-height',`${navLinks.scrollHeight}px`);
        })
        resizeObserver.observe(navLinks);
        openHumburgerButton.addEventListener('click',()=>{
            this.classList.toggle("open-humburger");
        })
    }
}
customElements.define("my-nav",Navigation);

</script>
