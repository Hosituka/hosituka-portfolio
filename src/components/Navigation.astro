---
//#グローバルナビゲーションに関するアストロファイル
function isActive(path:string):boolean{
	const pathname = Astro.url.pathname;
	switch(pathname){
		case path:
			return true;
		case path + '/':
			return true;
		default:
			return false;
	}
}

const topURL:string = "/";
const aboutMeURL:string = "/aboutMe"
const worksURL:string =  "/works";
const devLogURL:string = "/blog";
---
<!-- ##グローバルナビゲーションの要素ノード-->
<my-nav role="navigation">
	<div class="nav-links">
		<a href={topURL} class:list={[{"is-current":isActive(topURL)}]}>ホーム</a>
		<a href={aboutMeURL} class:list={[{"is-current":isActive(aboutMeURL)}]}>自己紹介</a>
		<a href={worksURL} class:list={[{"is-current":isActive(worksURL)}]}>作品</a>
		<a href={devLogURL} class:list={[{"is-current":isActive(devLogURL)}]}>日誌</a>
	</div>
	<div class="logo">
		Portfolio
	</div>
	<button class="hamburger-button">
		<span class="bar1"></span>
		<span class="bar2"></span>
		<span class="bar3"></span>
	</button>
</my-nav>
<!-- ##グローバルナビゲーションのスタイル-->
<style lang="scss">
@use '../styles/_utility' as *;
@layer Layout{
	my-nav {
		position: fixed;
		z-index: 1000;
		top: 0px;
		.logo{
			position:absolute;
			left:5px;
			top:0px;
			display: none;
		}
		.nav-links{
			position:relative;
			margin: 0px;
			display: flex;
			justify-content: space-around;
			align-items: center;
			a {				
				position:relative;
				display: flex;
				justify-content: center;
				align-items: center;
				&::after{
					position:absolute;
					bottom:7px;
					left:50%;
					transform:translateX(-50%);
				}
			}
		}
		.hamburger-button{
			position:absolute;
			top:0px;
			right:20px;
			display:none;
			& > * {
				transform-origin: center;
				position:absolute;
				left:0px;
			}
			.bar1{
				transform:translateY(-15px);
			}
			.bar2{
				transform:translateY(-3px);
			}
			.bar3{
				transform:translateY(9px);
			}
		}
	}
}
@layer Appearance{
    my-nav {
		width: 100%;
		height:auto;
		background-color: rgba($dark-gray,0.9);
		.logo{
			color:white;
			font-family: sans-serif;
			font-size: 40px;
			font-weight: 900;	
		}
		.nav-links{
			width: 100%;

			a{
				width: 25%;
				height:50px;
				border-bottom: 1px solid gray;

				font-size: 1.5rem;
				font-family: sans-serif;
				color: white;
				text-decoration: none;
				white-space:nowrap;
				&:not(:last-child){
					border-right: 1px solid gray;
				}

				&::after{
					width:0%;
					height:3px;
					background-color: white;
					content:"";
					transition:width 0.3s ease-out;
				}
				&:hover::after{
					width:90%;
				}
			}
			a.is-current{
				background-color: gray;
				border-bottom: 1px solid black;

				color:black;
				&::after{
					background-color: black;
				}
			}
		}
		.hamburger-button{
			width:40px;
			height:50px;
			border:none;
			padding:0px;
			background-color: transparent;
			& > * {
				width:100%;
				height:5px;
				background-color: white;
			}
			.bar1{
				transition:transform 0.3s ease-out;}
			.bar2{
				transition:opacity 0.3s ease-out;}
			.bar3{
				transition:transform 0.3s ease-out;}
		}
	}
}
@media (max-width:790px) {
	my-nav{
		height:50px;
		overflow-y: hidden;
		transition:height 0.3s ease-in-out; 
		border-bottom: 2px solid white;
		.logo{
			display: block;
		}
		.nav-links{
			padding-top:50px;
			flex-direction: column;
			left:calc(-1 * 100dvw);
			transition:transform 0.3s ease-in-out;
			a{
				display: flex;
				width:100%;
				border:none;
				&:first-child{
					border-top:1px solid white;
				}
				&:not(:last-child){
					border-bottom:1px solid white;
				}
			}
		}
		.hamburger-button{
			display:block;
		}
	}
	my-nav.open-hamburger{
		height:var(--nav-links-height);
		.hamburger-button{
			.bar1{
				transform:translateY(-3px) rotateZ(45deg);
			}
			.bar2{
				opacity:0;
			}
			.bar3{
				transform:translateY(-3px) rotateZ(-45deg);
			}
		}
		.nav-links{
			height:auto;
			display:flex;
			transform:translateX(100dvw);
		}
	}
}
</style>
<script>

class Navigation extends HTMLElement{
	private resizeObserver:ResizeObserver|null = null;
	private hamburgerButton:HTMLElement|null = null;
    connectedCallback(){
        requestAnimationFrame(this.start);
    }
    private start=() =>{
        this.hamburgerButton= this.querySelector(".hamburger-button");
        if(!this.hamburgerButton){console.error(".hamburger-buttonが見つかりません");return;}
        const navLinks:HTMLElement|null = this.querySelector(".nav-links");
        if(!navLinks){console.error(".nav-linksが見つかりません");return;}

        this.style.setProperty('--nav-links-height',`${navLinks.scrollHeight}px`);

        this.resizeObserver = new ResizeObserver(()=>{
            this.style.setProperty('--nav-links-height',`${navLinks.scrollHeight}px`);
        })
        this.resizeObserver.observe(navLinks);
        this.hamburgerButton.addEventListener('click',this.openHumburger)
    }
	private openHumburger=()=>{
		this.classList.toggle("open-hamburger");
	}
	disconnectedCallback(){
		if(!this.resizeObserver || !this.hamburgerButton) return;
		this.resizeObserver.disconnect();
		this.resizeObserver = null;

		this.hamburgerButton.removeEventListener('click',this.openHumburger);
		this.hamburgerButton = null;
	}
}
if(!customElements.get("my-nav")){
	customElements.define("my-nav",Navigation);
}

</script>
