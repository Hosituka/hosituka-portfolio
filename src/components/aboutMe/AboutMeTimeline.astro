    </li>


</about-me-timeline>
<style lang="scss">
@use '../../styles/_utility' as *;
$vertical-line-width:8px;
$column-gap:10px;
$max-li-count:6;
$left-li-horizontal-line-width:$column-gap  + 2;
$right-li-horizontal-line-width:$column-gap + 3;

@layer Layout{

    about-me-timeline{
        display:grid;
        grid-template-columns: 1fr $vertical-line-width 1fr;
        row-gap: 40px;
        column-gap: $column-gap;
        &::before{
            grid-column: 2;
            grid-row:1 / span $max-li-count;
        }
        li{
            position:relative;
            @for $i from 1 through $max-li-count{
                &:nth-child(#{$i}){
                    grid-row:$i;
                }
            }
            &::before{
                position:absolute;
                top:-1px;
            }
            &:first-child{
                margin-top:20px;
            }
            &:last-child{
                margin-bottom:20px;
            }


            //#ある階層の上から数えて奇数の時
            &:nth-child(odd){
                grid-column: 1;
                justify-self:end;

                &::before{
                    right:-1 * $left-li-horizontal-line-width ;
                }

            }
            &:nth-child(even){
                grid-column: 3;
                justify-self: start;

                margin-left: 1px;
                &::before{
                    left:-1 * $right-li-horizontal-line-width ;
                }

            }
        }  
    }
}
@layer Appearance{
    about-me-timeline{
        width:fit-content;
        list-style: none;
        &::before{
            width: $vertical-line-width;
            height:100%; 
            background-color: $light-yellow;
            box-shadow: 2px 2px 2px black;
            border:1px solid black;
            content: "";
        }
        li{
            width:400px;
            height:200px;
            border:1px solid black;
            box-shadow: 2px 2px 2px black;
            background-color: $light-yellow;
            &::before{
                height:5px;
                border-top: 1px solid black;
                border-bottom: 1px solid black;
                box-shadow: 0px 1px 0px black;
                content: "";
            }
            h2{
                width:100%;
                height:40px;
                background-color: $yellow;
                border-bottom: 1px solid black;
            }
            //#ある階層の上から数えて奇数の時
            &:nth-child(odd){
                border-top-left-radius: 40px;
                &::before{
                    width:$left-li-horizontal-line-width;
                    background-image:linear-gradient(90deg,$yellow,$light-yellow);
                }
                h2{
                    border-top-left-radius: 40px;
                }

            }
            &:nth-child(even){
                border-top-right-radius: 40px;
                &::before{
                    width:$right-li-horizontal-line-width;
                    background-image:linear-gradient(90deg,$light-yellow,$yellow);
                }
                h2{
                    border-top-right-radius: 40px;
                }

            }

        }
    }
}
@media (max-width:1000px) {
    about-me-timeline{
        display:grid;
        grid-template-columns: $vertical-line-width 1fr;
        row-gap: 40px;
        column-gap: $column-gap;
        &::before{
            grid-column: 1;
            grid-row:1 / span $max-li-count;
        }
        li{
            position:relative;
            justify-self: start;
            grid-column: 2;
            margin-left: 1px;

            border-radius: 0;
            border-top-right-radius: 40px;
            &::before{
                width:$right-li-horizontal-line-width;
                left:-1 * $right-li-horizontal-line-width;
                background-image:linear-gradient(90deg,$light-yellow,$yellow);
            }
            h2{
                border-radius: 0;
                border-top-right-radius: 40px;
            }
        }  
    }
}
@media (max-width:450px) {
    about-me-timeline{
        li{
            width:320px;
        }
    }
}
</style>