---
<skill-md-content>
    <slot/>
</skill-md-content>
<style is:global lang="scss">
@use '../../styles/utility' as *;
@layer Layout{
    skill-md-content{
        display:block;
        video{
            position:relative;
            left:50%;
            transform:translateX(-50%);
            margin:10px 0px;
        }
        h1,h2{
            margin:5px 0px;
        }
        p{
            margin:8px 0px;
        }
        ul{
            li{
                position:relative;
                margin:7px 0px;
                &::before{
                    position:absolute;
                    left:0px;
                    top:6px;
                }
            }
        }
    }
}
@layer Appearance{
    skill-md-content{
        padding:5px 10px;
        h1{
            font-size:30px;
            padding-left:5px;
            border-left:10px solid $yellow;
            @media(max-width:500px){
                font-size:25px;  
            }
        }
        h2{
            font-size:25px;
            padding-bottom: 5px;
            border-bottom: 1px solid black;
            @media(max-width:500px){
                font-size:20px;  
            }

        }
        video{
            width:100%;
            max-width:450px;
        }
        ul{
            list-style: none;
            li{
                padding-left:15px;
                line-height: 1.2;
                &::before{
                    aspect-ratio: 1/1;
                    height:8px;
                    border-radius:50%;
                    background-color: black;
                    content: "";
                }

            }
        }
    }
}
</style>