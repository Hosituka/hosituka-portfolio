---
//これは音声波形のアニメーションを表示するuiコンポーネントです。
interface Props{
    maxHeight:number;
    zIndex?:string;
    yOffset?:number;
}
const {zIndex='auto',yOffset = 0,maxHeight}:Props = Astro.props;
---
<frequency-bar style={`--z-index:${zIndex}`} data-y-offset={yOffset} data-max-height={maxHeight}>
    <canvas>
    </canvas>
</frequency-bar>

<style lang="scss">
@layer Layout{
    frequency-bar{
        position:absolute;
        display:block;
        z-index:2;
        canvas{
            
        }
    }
}
@layer Appearance{
    frequency-bar{
        width:100%;
        height:100%;
        canvas{
            width:100%;
            height:100%;
        }
    }
}
</style>

<script>
import {type Vector2,MathUtility,Time} from '../scripts/utility'


    //#音声波形の縦棒一つ一つに対応するクラス
    class VerticalBar{
        private pos:Vector2 = {x:0,y:0};
        private size:Vector2 = {x:5,y:100}
        private targetFrequencBar:FrequencyBar|null = null;
        constructor(xPos:number,yPos:number,frequencBar:FrequencyBar){
            this.pos.x = xPos;
            this.pos.y = yPos;
            this.targetFrequencBar = frequencBar;
        }
        Draw=(ctx2D:CanvasRenderingContext2D,maxHeight:number):void=>{
            if(!this.targetFrequencBar)return;
            const restrain:Function = (x:number,offset:number,canvasWidth:number,ridgeMinHeightRate:number,ridgeWidth:number):number=>{
                //#グラフにおいて_Λ_みたいな形を作るための処理※この見出しの中にある##はoffsetが0であると仮定している。
                let value = x - offset;
                //##value∈[0,1]
                value = value / canvasWidth
                //##value∈[-1,1]
                value = value * 2 - 1;
                //##value∈[0,1],グラフにおいてv字にする
                value = Math.abs(value);
                //##グラフにおいてΛ字にする。
                value = 1 - value;
                console.log(value);
                //#offsetが正の数だとvalueが負の数になる。つまりpow関数において不正な値となるためそれを防ぐ処理
                value = Math.max(value,0);
                //#隆起の幅がcanvasWidthに比例していたが、それを固定&決める処理
                value = Math.pow(value,canvasWidth/ridgeWidth);
                //#隆起の最低の高さを設ける処理
                value = MathUtility.Clamp(value,ridgeMinHeightRate,1 - ridgeMinHeightRate);

                return value;
            }
            ctx2D.fillStyle = "white";
                          this.size.y = MathUtility.Fbm(this.pos.x * 0.01 + Time.TimeInSeconds * 0.2,this.pos.y,4) *
                          maxHeight *
                          restrain(this.pos.x,125,this.targetFrequencBar.clientWidth,0.2,75);
            const halfSizeY = this.size.y / 2;
            ctx2D.fillRect(this.pos.x,this.pos.y - halfSizeY,this.size.x,this.size.y);
        }
    }
    //#VerticalBarを制御するクラス
    class FrequencyBar extends HTMLElement{
        AllBarMaxHeight:number = 0;
        private BarWidth:number = 5;
        private canvas:null|HTMLCanvasElement=null;
        private ctx2D:null|CanvasRenderingContext2D=null;
        private verticalBars:VerticalBar[] = [];
        private barSpacing:number = 10;
		connectedCallback(){
            this.canvas = this.querySelector('canvas');
            if(!this.canvas){console.error('canvas要素がみつかりません');return}
            this.ctx2D = this.canvas.getContext('2d');

            requestAnimationFrame(this.GenerateVerticalBar);
            requestAnimationFrame(this.Update);
            //#リサイズを検知するための初期化
			const observer = new ResizeObserver(() => {
				this.OnResize();
			});
			observer.observe(this);

        }
        private OnResize=():void=>{
            this.verticalBars = [];
            this.GenerateVerticalBar();
        }
        private GenerateVerticalBar=():void=>{
            if(!this.canvas){return};
            //#解像度を指定するコード
            this.canvas.width = this.clientWidth;
            this.canvas.height = this.clientHeight;
            //#バーの挙動に必要な情報を流し込む処理
            if(!this.dataset.maxHeight){console.error('maxHeightというカスタム属性が存在しません');return;}
            this.AllBarMaxHeight = parseFloat(this.dataset.maxHeight) * this.clientHeight;

            //#縦のバーを等間隔で生成するコード
            const barX_Step = this.barSpacing + this.BarWidth;
            const targetBarCount = Math.ceil(this.clientWidth / barX_Step);
            const halfClientHeight:number = this.clientHeight / 2;
            console.log(targetBarCount);
            //console.log('生成目標となるバーの数：' + targetBarCount)
            //##data属性から生成に用いる値を取得するコード
            if(!this.dataset.yOffset){console.error('yOffsetというカスタム属性が存在しません');return;}
            const yOffset:number = parseFloat(this.dataset.yOffset);
            //##実際に縦のバーの位置を決めながら生成するコード
            for(let barCount=0;barCount<targetBarCount;barCount++){
                this.verticalBars.push(new VerticalBar(barCount * barX_Step,halfClientHeight + yOffset,this));
            }
        }
        //#毎フレームの描画前に呼ばれる関数
        private Update=():void=>{
            if(!this.canvas||!this.ctx2D){return};
            this.ctx2D.clearRect(0,0,this.clientWidth,this.clientHeight);
            for(const verticalBar of this.verticalBars){
                verticalBar.Draw(this.ctx2D,this.AllBarMaxHeight);
            }
            requestAnimationFrame(this.Update);
        }
    }
    customElements.define('frequency-bar',FrequencyBar);
</script>
