---
//#これはカルーセルのuiコンポーネントを定義する所です。カルーセルの構成要素となるカードについてはSlotで親コンポーネントから差し込まれるという仕様にする予定です。
interface Props {
    speed:number;
}
const {speed}:Props = Astro.props;
---
<my-carousel data-speed={speed}>
    <div class="cards-container">
        <slot/>
    </div>
</my-carousel>

<style lang='scss'>
@layer Layout{
    //#cards-containerを表示する窓の役割
    my-carousel{
        display:block;
        //#カードたちを入れる箱こいつをx軸方向で動かす。
        .cards-container{
            display:flex;
            gap:10px;
            will-change: transform;
        }
    }
}
@layer Appearance{
    my-carousel{
        width:100%;
        overflow-x:hidden;
        padding:5px 0px 5px 0px;
        cursor:grab;
        &:active{
            cursor:grabbing;
        }
        .cards-container{
            width:fit-content;
        }
    }
}
</style>
<script>
    import {MathUtility, Time,PointerSystem} from '../scripts/utility'
    class MyCarousel extends HTMLElement{
        //#このインスタンスのインスタンス関数メンバ全体で使われる識別子
        private cardsContainer:HTMLElement|null=null;
        private carouselViewport:HTMLElement|null = null;
        //#この関数はインスタンスとして格納されるカスタム要素が生成された瞬間に走る処理、つまり他の要素に安全にアクセスできるとは限らない
		connectedCallback(){
            //#他の要素に安全にアクセスするため、次の描画前に走るコールバックとして登録する。
            //##一回だけ走る処理の購読
            requestAnimationFrame(this.Start);
            //##恒常的に走る処理の購読
            requestAnimationFrame(this.Update);              
        }
        //#Start内で購読する用の関数内で使われる識別子
        private hovering:boolean = false;
        private dragging:boolean = false;

        //##スマホ用の識別子
        private timerId:number= 0;
        //##autoScroll用の識別子
        private scrollHalfWidth:number=0;
        private currentX:number = 0;

        private speed:number = 1;

        private Start=()=>{
            const CarouselInitialize=()=>{
                //#カルーセルをするための準備
                //##カルーセル出来るかどうかの確認
                this.cardsContainer = this.querySelector('.cards-container');
                if (!this.cardsContainer) {console.error(".cards-containerが見つかりませんでした。");
                    return;}

                //##ここでカスタム属性の値をspeedに入れる。
                if(this.dataset.speed!==undefined)
                {this.speed = parseFloat(this.dataset.speed)}
                else{this.speed = 5;}
                //##カルーセルのスクロールを受けても余白が生じない程の量のカードを用意する。
                //### ビューポートの横幅を埋め尽くす分のカードを生成
                let cardArray:Array<Element> = Array.from(this.cardsContainer.children);
                const allCardWidth:number = this.cardsContainer.scrollWidth;
                const viewPortWidth:number = document.documentElement.clientWidth;
                const targetCopyCount:number = Math.floor(viewPortWidth / allCardWidth);
                for(let i = 0;i < targetCopyCount;i++){
                    for(const item of cardArray){
                        const cloneItems = item.cloneNode(true);
                        this.cardsContainer.appendChild(cloneItems);
                    }
                }
                //###上の工程で作られたカード群を二倍増やす
                cardArray = Array.from(this.cardsContainer.children);
                for(const item of cardArray){
                    const cloneItems = item.cloneNode(true);
                    this.cardsContainer.appendChild(cloneItems);
                }
                //##スクロールする閾値となる値の計算
                //###このコンポーネントの内部scssで指定しているgap
                const gap = 10;
                this.scrollHalfWidth = (this.cardsContainer.scrollWidth + gap) / 2;

                //#イベント関係の処理の登録&定義
                //##PCのタッチイベント
                this.addEventListener("mouseenter",this.StartHover)
                this.addEventListener("mousedown", this.StartDrag)

                this.addEventListener("mouseup", this.EndDrag)
                this.addEventListener("mouseleave",this.StartAutoScroll);

                //##スマホのタッチイベント
                this.addEventListener("touchstart", this.EnableInteraction)
                this.addEventListener("touchend",this.ScheduleAutoScroll)
                this.addEventListener("touchcancel",this.ScheduleAutoScroll)

            }
            //#workCardOfCarousel.astro用の処理
            const CardInitialize=()=>{
                this.addEventListener('request-card-overview-visibility',this.DispatchSyncCardsOverview)
            }
            CarouselInitialize();
            CardInitialize();
        }
        private StartHover=()=>this.hovering = true;
        private StartDrag=()=>this.dragging = true;
        private EndDrag=()=>this.dragging = false;
        private ScheduleAutoScroll=()=>this.timerId = setTimeout(this.StartAutoScroll, 500);
        private EnableInteraction=()=>{
            this.hovering = true;
            this.dragging = true;
            clearTimeout(this.timerId);
        }
        private DispatchSyncCardsOverview=(e:any)=>{
            this.dispatchEvent(new CustomEvent('sync-card-overview-visibility',
            {
                detail:e.detail
            }));
        }
        //#恒常的(毎フレーム)に走る処理
        private Update=()=>{
            //#現状自動でスクロールする処理が書かれている。
            if(!this.cardsContainer)return;

            if (!this.hovering && !this.dragging) {
                this.currentX += this.speed * Time.DeltaTime;
            }
            else if (this.hovering && this.dragging) {
                this.currentX += PointerSystem.DragDeltaPos.x;
            }
            this.currentX = MathUtility.Repeat(this.currentX,0, -this.scrollHalfWidth)
            this.cardsContainer.style.transform = `translateX(${this.currentX}px) translateZ(0)`;
            requestAnimationFrame(this.Update);
        }
        private StartAutoScroll=()=> {
            this.dragging = false;
            this.hovering = false;
        }
        disconnectedCallback(){
            this.removeEventListener("mouseenter",this.StartHover)
            this.removeEventListener("mousedown", this.StartDrag)

            this.removeEventListener("mouseup", this.EndDrag)
            this.removeEventListener("mouseleave",this.StartAutoScroll);

            //##スマホのタッチイベント
            this.removeEventListener("touchstart", this.EnableInteraction)
            this.removeEventListener("touchend",this.ScheduleAutoScroll)
            this.removeEventListener("touchcancel",this.ScheduleAutoScroll)

        }


    }
    if(!customElements.get('my-carousel')){
        customElements.define('my-carousel',MyCarousel);
    }
</script>